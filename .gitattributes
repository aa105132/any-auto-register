* text=auto

# 源码与配置统一使用 LF，避免 Windows/WSL 环境产生大面积伪 diff。
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf

# Windows 启动脚本保留 CRLF。
*.bat text eol=crlf
